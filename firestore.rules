rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the document belongs to the user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Generic rule for collections indexed by userId
    match /{collectionName}/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Specific rules for user profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Shared context / Locks (Admin-managed backend only)
    match /worker_locks/{docId} {
      allow read, write: if false; 
    }

    // Social Proof / Ticker
    match /transactions/{id} {
      // Allow social proof reading
      allow read: if true;
      // Only owner can write (though usually server-side)
      allow write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Public recent earning events (if any)
    match /payouts/{id} {
      allow read: if true;
      allow write: if false; 
    }

    // Immutable audit logs (for server only, but rules applies to client too)
    // In practice, client shouldn't write to these, only server.
    match /immutable_audit_logs/{id} {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side via Admin SDK
    }
    
    match /change_proposals/{id} {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side via Admin SDK enforcing governance boundaries
    }
    
    match /governance_audit_logs/{id} {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side via Admin SDK
    }
    
    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
