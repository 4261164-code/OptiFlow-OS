rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }

    function isValidJob(data) {
      return data.keys().hasAll(['keyword', 'status', 'userId', 'createdAt', 'updatedAt'])
        && data.keyword is string && data.keyword.size() <= 5000
        && data.status in ["pending", "running", "research", "writing", "pinterest", "monetization", "completed", "error"]
        && data.userId == request.auth.uid
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'content', 'keyword', 'jobId', 'userId', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 2000
        && data.content is string && data.content.size() <= 500000
        && data.keyword is string && data.keyword.size() <= 5000
        && data.jobId is string
        && data.userId == request.auth.uid
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function isValidPin(data) {
      return data.keys().hasAll(['title', 'description', 'concept', 'articleId', 'jobId', 'userId', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 2000
        && data.description is string && data.description.size() <= 10000
        && data.concept is string && data.concept.size() <= 10000
        && (!data.keys().hasAny(['imageUrl']) || data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 2000000))
        && data.articleId is string
        && data.jobId is string
        && data.userId == request.auth.uid
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function isValidOffer(data) {
      return data.keys().hasAll(['brand', 'keyword', 'link', 'userId', 'createdAt', 'updatedAt'])
        && data.brand is string && data.brand.size() <= 500
        && data.keyword is string && data.keyword.size() <= 500
        && data.link is string && data.link.size() <= 5000
        && (!data.keys().hasAny(['anchor']) || data.anchor == null || (data.anchor is string && data.anchor.size() <= 1000))
        && (!data.keys().hasAny(['description']) || data.description == null || (data.description is string && data.description.size() <= 10000))
        && data.userId == request.auth.uid
        && data.createdAt is number
        && data.updatedAt is number;
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidJob(incoming());
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid 
        && isValidJob(incoming())
        && incoming().userId == resource.data.userId
        && incoming().createdAt == resource.data.createdAt;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /articles/{articleId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidArticle(incoming());
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid 
        && isValidArticle(incoming())
        && incoming().userId == resource.data.userId
        && incoming().createdAt == resource.data.createdAt;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /pins/{pinId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidPin(incoming());
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid 
        && isValidPin(incoming())
        && incoming().userId == resource.data.userId
        && incoming().createdAt == resource.data.createdAt;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /offers/{offerId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidOffer(incoming());
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid 
        && isValidOffer(incoming())
        && incoming().userId == resource.data.userId
        && incoming().createdAt == resource.data.createdAt;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /settings/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || userId == request.auth.uid + '_test');
    }
  }
}
